# 데이터 위치 (UNC 또는 로컬 경로)
PRECEDENT_DATA_DIR=\\192.168.0.17\Code\Python\precedent\data

# Chroma DB 영구 저장 위치
CHROMA_DIR=./chroma_db

# 임베딩 모델 (BGE-M3: 한국어 강함, 첫 실행 시 약 2GB 다운로드)
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cpu

# Ollama (한국어 강한 모델 추천: qwen2.5:14b, exaone3.5:7.8b, gemma2:9b 등)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# 색인 소스: db (MariaDB precedent 테이블) | jsonl (기존 파일)
INDEX_SOURCE=db

# ── MariaDB 접속 ────────────────────────────────────────────────
# 기본 동작: Java 와 동일한 "시스템 환경변수" LAWSYSTEM_DB_* 를 자동 재사용한다.
#   LAWSYSTEM_DB_URL=jdbc:mariadb://<DB_PC_IP>:3306/law_system?useUnicode=true&characterEncoding=utf8
#   LAWSYSTEM_DB_USER / LAWSYSTEM_DB_PASSWORD / LAWSYSTEM_DB_DATABASE
# → 위 값들이 OS 환경변수로 잡혀 있으면 아래 PRECEDENT_DB_* 는 적지 않아도 된다.
#   (JDBC URL 에서 host/port/database 를 자동으로 파싱한다.)
#
# 다른 DB 를 쓰거나 값을 강제로 덮어쓰고 싶을 때만 아래 주석을 풀어 override.
# PRECEDENT_DB_HOST=192.168.0.A
# PRECEDENT_DB_PORT=3306
# PRECEDENT_DB_USER=lawuser
# PRECEDENT_DB_PASSWORD=
# PRECEDENT_DB_NAME=law_system
